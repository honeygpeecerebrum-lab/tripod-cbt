<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<title>Tripod Online Tutorial CBT</title>
<style>
body { font-family: Arial; background:#0f172a; color:white; text-align:center; }
.box { background:#1e293b; padding:20px; margin:30px auto; width:320px; border-radius:10px; }
input, button { padding:10px; margin:10px; width:90%; }
button { background:#22c55e; border:none; color:white; cursor:pointer; }
table { width:100%; color:white; }
</style>
</head>
<body><div id="intro" class="box">
<h2>Welcome to TRIPOD ONLINE TUTORIAL 🎓</h2>
<p>Prepare yourself and click below to begin</p>
<button onclick="showLogin()">Enter</button>
</div><div id="login" class="box" style="display:none;">
<h3>Admin Login</h3>
<input id="user" placeholder="Username"><br>
<input id="pass" type="password" placeholder="Password"><br>
<button onclick="login()">Login</button>
</div><div id="candidate" class="box" style="display:none;">
<h3>Candidate Details</h3>
<input id="name" placeholder="Full Name"><br>
<input id="phone" placeholder="Phone Number"><br>
<button onclick="startExam()">Start Exam</button>
</div><div id="exam" class="box" style="display:none;">
<h3 id="q"></h3>
<div id="opts"></div>
<button onclick="next()">Next</button>
</div><div id="result" class="box" style="display:none;"></div><div id="leaderboard" class="box" style="display:none;">
<h3>Leaderboard 🏆</h3>
<table id="board"></table>
</div><div id="adminPanel" class="box" style="display:none;">
<h3>Admin Dashboard</h3>
<table id="adminTable"></table>
</div><script>
const ADMIN = "admin";
const PASSWORD = "1234";

let candidates = JSON.parse(localStorage.getItem("cbtData")) || [];

function showLogin(){
 document.getElementById("intro").style.display="none";
 document.getElementById("login").style.display="block";
}

function login(){
 let u = user.value;
 let p = pass.value;
 if(u===ADMIN && p===PASSWORD){
  document.getElementById("login").style.display="none";
  document.getElementById("adminPanel").style.display="block";
  loadAdmin();
 } else {
  document.getElementById("login").style.display="none";
  document.getElementById("candidate").style.display="block";
 }
}

let questions = [
 {q:"2+2?", o:["2","4","6","8"], a:"4"},
 {q:"Capital of Nigeria?", o:["Lagos","Abuja","Kano","Ibadan"], a:"Abuja"}
];

let i=0, score=0, currentName="", currentPhone="";

function startExam(){
 currentName = name.value;
 currentPhone = phone.value;
 if(!currentName || !currentPhone){ alert("Fill details"); return; }
 document.getElementById("candidate").style.display="none";
 document.getElementById("exam").style.display="block";
 loadQ();
}

function loadQ(){
 let c = questions[i];
 q.innerText = c.q;
 let html="";
 c.o.forEach(opt=>{
  html += `<label><input type='radio' name='opt' value='${opt}'> ${opt}</label><br>`;
 });
 opts.innerHTML = html;
}

function next(){
 let sel = document.querySelector("input[name='opt']:checked");
 if(!sel){ alert("Select answer"); return; }
 if(sel.value===questions[i].a) score++;
 i++;
 if(i<questions.length){ loadQ(); }
 else finish();
}

function finish(){
 let result = {name:currentName, phone:currentPhone, score:score};
 candidates.push(result);
 localStorage.setItem("cbtData", JSON.stringify(candidates));

 document.getElementById("exam").style.display="none";
 document.getElementById("result").style.display="block";
 document.getElementById("leaderboard").style.display="block";

 result.innerHTML = `<h2>Finished</h2><p>${currentName}, Score: ${score}</p>`;
 loadBoard();
}

function loadBoard(){
 let sorted = candidates.sort((a,b)=>b.score-a.score);
 let html = "<tr><th>Name</th><th>Score</th></tr>";
 sorted.forEach(c=>{
  html += `<tr><td>${c.name}</td><td>${c.score}</td></tr>`;
 });
 board.innerHTML = html;
}

function loadAdmin(){
 let html = "<tr><th>Name</th><th>Phone</th><th>Score</th></tr>";
 candidates.forEach(c=>{
  html += `<tr><td>${c.name}</td><td>${c.phone}</td><td>${c.score}</td></tr>`;
 });
 adminTable.innerHTML = html;
}
</script></body>
</html> 